# Website deployment ignore file
# Add files/folders you don't want to deploy

# Development files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.sublime-*
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp
.cache/

# Backup files
*.bak
*.backup

# Optional - if you create optimized versions
*_original.*
*_backup.*

# Node modules (if you add build tools later)
node_modules/

# Build outputs (if you add build process)
dist/
build/
